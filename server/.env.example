PORT=8747
NODE_ENV=development
APP_ENV=development
# See also: .env.development.example, .env.staging.example, .env.production.example
JWT_KEY="@#%$#$%^&*&^%%^&*%^&*^^&*%^&*&%%^(*&^%^&*&%^%$%)"
JWT_KEY_ID=current
JWT_KEY_PREVIOUS=
JWT_ISSUER=connectnow-api
JWT_AUDIENCE=connectnow-web
ORIGIN=http://localhost:5173
DATABASE_URL=mongodb+srv://replace-with-staging-uri

SESSION_DURATION_MS=259200000
IDLE_TIMEOUT_MS=1800000
SINGLE_SESSION_MODE=false
JSON_BODY_LIMIT=2mb
FORM_BODY_LIMIT=1mb
GLOBAL_RATE_LIMIT=500
GLOBAL_RATE_LIMIT_WINDOW_MS=900000
AUTH_SYNC_RATE_LIMIT=20
AUTH_DEVICE_RATE_LIMIT=8
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_LOCK_THRESHOLD=8
AUTH_TEMP_LOCK_MS=900000
CLERK_REQUIRE_VERIFIED_EMAIL=true
MFA_MAX_AGE_MINUTES=60
SENSITIVE_ACTION_ASSURANCE_LEVEL=2
TRUSTED_DEVICE_DURATION_MS=2592000000
IMPOSSIBLE_TRAVEL_WINDOW_MS=3600000
REQUEST_REPLAY_WINDOW_MS=300000
SESSION_TOUCH_INTERVAL_MS=60000
AUTH_USER_IP_RATE_LIMIT=12
UPLOAD_INTENT_RATE_LIMIT=60
UPLOAD_INTENT_RATE_LIMIT_WINDOW_MS=900000
MIN_HUMAN_RENDER_TIME_MS=1200
DISPOSABLE_EMAIL_DOMAINS=
CAPTCHA_PROVIDER=turnstile
CAPTCHA_SECRET_KEY=
CAPTCHA_ENFORCE_AUTH=false
SECURITY_EMAIL_ALERTS_ENABLED=true
SECURITY_ALERT_FROM=
SECURITY_ALERT_EMAIL=
AUDIT_LOG_EXPORT_LIMIT=10000
SECURITY_LOG_RETENTION_DAYS=180
SIGNED_UPLOAD_MAX_BYTES=52428800

CLERK_SECRET_KEY=your-clerk-secret-key
# EMAIL=replace-with-email
# EMAIL_PASSWORD=replace-with-app-password
OPENAI_API_KEY=replace-with-openai-key
OPENAI_MODEL=gpt-4.1-mini
GEMINI_API_KEY=replace-with-gemini-key
GEMINI_MODEL=gemini-2.5-flash

RAZORPAY_KEY_ID=razorpay-key
RAZORPAY_KEY_SECRET=secret-key
RAZORPAY_PREMIUM_AMOUNT=29900
RAZORPAY_CURRENCY=INR
RAZORPAY_WEBHOOK_SECRET=replace-with-webhook-secret

SUPABASE_URL=your-supabase-url
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=service-role-key
SUPABASE_STORAGE_BUCKET=chat-media
